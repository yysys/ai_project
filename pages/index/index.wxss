/* index.wxss */
.container {
  padding: 40rpx 20rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: flex-start;
}

/* 页面标题区域 */
.page-header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.logo {
  width: 150rpx;
  height: 150rpx;
  margin: 20rpx 0;
}

.app-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.app-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
}

/* 功能介绍区域 */
.features {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300rpx, 1fr));
  gap: 30rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx;
  background-color: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
}

.feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  text-align: center;
}

.feature-desc {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

/* 开始飞行按钮 */
.start-section {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.start-btn {
  width: 60%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  background-color: #1890ff;
  color: white;
  border-radius: 45rpx;
  font-size: 36rpx;
  margin-bottom: 20rpx;
  border: none;
}

.start-btn::after {
  border: none;
}

/* 用户信息 */
.user-section {
  width: 100%;
  display: flex;
  justify-content: center;
}

.user-info {
  display: flex;
  align-items: center;
  padding: 20rpx 40rpx;
  background-color: white;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.username {
  font-size: 24rpx;
  color: #333;
}

/* 横屏响应式设计 */
@media (orientation: landscape) {
  .container {
    padding: 20rpx;
  }
  
  .features {
    grid-template-columns: repeat(3, 1fr);
  }
  
  .start-btn {
    width: 40%;
  }
}
