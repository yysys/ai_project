/* flight.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-rows: auto 1fr auto;
  gap: 20rpx;
}

/* 页面标题 */
.page-title {
  grid-column: 1 / -1;
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 10rpx 0;
  color: #333;
}

/* 状态信息面板 */
.status-panel {
  grid-column: 1 / -1;
  display: flex;
  justify-content: space-around;
  background-color: white;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.status-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.status-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

/* 无人机飞行区域 */
.drone-container {
  grid-column: 1 / -1;
  position: relative;
  background-color: #e6f7ff;
  border-radius: 20rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
}

.drone-image {
  width: 200rpx;
  height: 200rpx;
  z-index: 10;
  transition: transform 0.3s ease;
}

.map-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.6;
}

.map-background image {
  width: 100%;
  height: 100%;
}

/* 控制区域 */
.control-section {
  grid-column: 1 / -1;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 控制按钮面板 */
.control-panel {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 10rpx 0;
}

.control-btn {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin: 0 60rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  transition: all 0.2s ease;
}

.control-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.control-btn::after {
  border: none;
}

.speed-up {
  background-color: #52c41a;
  color: white;
}

.speed-down {
  background-color: #ff4d4f;
  color: white;
}

/* 状态栏 */
.status-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background-color: white;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.gyro-status {
  display: flex;
  align-items: center;
}

.gyro-label {
  font-size: 24rpx;
  color: #666;
  margin-right: 10rpx;
}

.gyro-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

/* 操作提示 */
.tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 10rpx;
}

/* 横屏响应式设计 */
@media (orientation: landscape) {
  .container {
    padding: 10rpx;
    gap: 15rpx;
  }
  
  .drone-container {
    min-height: 600rpx;
  }
  
  .control-btn {
    width: 180rpx;
    height: 180rpx;
    margin: 0 80rpx;
  }
  
  .status-panel {
    padding: 15rpx;
  }
  
  .status-value {
    font-size: 36rpx;
  }
}
