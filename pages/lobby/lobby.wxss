/* pages/lobby/lobby.wxss */
.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
}

.bg-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -2;
}

.overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4); /* 半透明遮罩 */
  z-index: -1;
}

/* 顶部信息栏 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 40rpx;
  background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0));
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx solid #00ff00;
  margin-right: 20rpx;
}

.user-details {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.5);
}

.currency {
  font-size: 24rpx;
  color: #ffd700;
  margin-top: 5rpx;
}

.settings-btn {
  background: rgba(0, 0, 0, 0.5);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  font-size: 24rpx;
  display: flex;
  align-items: center;
}

.settings-btn .icon {
  margin-right: 10rpx;
}

/* 主要内容区 - 居中 */
.main-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.game-mode-card {
  width: 300rpx;
  height: 180rpx;
  background: rgba(0, 50, 0, 0.8);
  border: 2rpx solid #00ff00;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 20rpx rgba(0, 255, 0, 0.3);
  transition: all 0.2s;
}

.game-mode-card:active {
  transform: scale(0.95);
  background: rgba(0, 80, 0, 0.9);
}

.mode-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.mode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #00ff00;
}

.mode-desc {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 5rpx;
}

/* 底部功能栏 */
.footer {
  position: absolute;
  bottom: 40rpx;
  right: 40rpx;
}

.menu-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.6);
  border: 2rpx solid #ffaa00;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  box-shadow: 0 0 15rpx rgba(255, 170, 0, 0.3);
}

.menu-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 5rpx;
}

.btn-text {
  font-size: 20rpx;
  color: #ffaa00;
}

/* 弹窗通用样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  background: rgba(10, 20, 30, 0.95);
  border: 2rpx solid #00aaff;
  border-radius: 20rpx;
  padding: 30rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80%;
  display: flex;
  flex-direction: column;
  box-shadow: 0 0 30rpx rgba(0, 170, 255, 0.3);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.1);
  padding-bottom: 20rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #00aaff;
}

.close-btn {
  font-size: 40rpx;
  color: #aaa;
  padding: 10rpx;
}

/* 商城样式 */
.store-tabs {
  display: flex;
  margin-bottom: 20rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 15rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #aaa;
  font-size: 28rpx;
}

.tab:first-child {
  border-top-left-radius: 10rpx;
  border-bottom-left-radius: 10rpx;
}

.tab:last-child {
  border-top-right-radius: 10rpx;
  border-bottom-right-radius: 10rpx;
}

.tab.active {
  background: #00aaff;
  color: #fff;
}

.store-list {
  flex: 1;
  overflow-y: auto;
}

.store-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  padding: 20rpx;
  margin-bottom: 15rpx;
  border-radius: 10rpx;
}

.item-img {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  background: rgba(0,0,0,0.3);
  border-radius: 10rpx;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.item-stats {
  font-size: 22rpx;
  color: #00ff00;
  margin: 5rpx 0;
}

.item-stats text {
  margin-right: 15rpx;
}

.item-desc {
  font-size: 20rpx;
  color: #888;
}

.item-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 20rpx;
}

.price {
  font-size: 24rpx;
  color: #ffd700;
  margin-bottom: 10rpx;
}

.buy-btn {
  font-size: 22rpx;
  padding: 10rpx 20rpx;
  background: #00aaff;
  color: #fff;
  border: none;
  line-height: 1.5;
}

.buy-btn[disabled] {
  background: #555;
  color: #999;
}

/* 设置样式 */
.settings-list {
  padding: 20rpx 0;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.05);
}

/* 新增图标样式 */
.settings-btn .icon-img {
  width: 30rpx;
  height: 30rpx;
  margin-right: 10rpx;
}

.menu-btn .btn-icon-img {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 5rpx;
}
