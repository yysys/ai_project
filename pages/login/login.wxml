<!-- login.wxml -->
<view class="login-container">
  <!-- 游戏背景视频 -->
  <view class="game-background">
    <video id="game-video" autoplay loop muted class="video">
      <source src="../../assets/videos/game-intro.mp4" type="video/mp4"></source>
    </video>
  </view>
  
  <!-- 游戏音效 -->
  <audio id="game-audio" src="../../assets/audio/bg-music.mp3" autoplay loop muted></audio>
  
  <!-- 游戏界面元素 -->
  <view class="game-interface">
    <!-- 游戏标题 -->
    <view class="game-header">
      <image src="../../assets/images/game-logo.png" alt="无人机飞行" class="logo"></image>
      <view class="title-container">
        <text class="game-title">无人机飞行</text>
        <text class="game-subtitle">沉浸式飞行体验</text>
      </view>
    </view>
    
    <!-- 游戏主内容 -->
    <view class="game-content">
      <view class="game-preview">
        <image src="../../assets/images/drone.png" alt="无人机" class="drone-image"></image>
        <view class="preview-text">
          <text class="preview-title">准备起飞</text>
          <text class="preview-subtitle">体验身临其境的飞行控制</text>
        </view>
      </view>
    </view>
    
    <!-- 游戏底部 -->
    <view class="game-footer">
      <!-- 加载进度条 -->
      <view class="loading-section">
        <view class="loading-header">
          <text class="loading-title">加载游戏资源</text>
          <text class="loading-percentage">{{loadingProgress}}%</text>
        </view>
        <view class="loading-bar-container">
          <view class="loading-bar" style="width: {{loadingProgress}}%"></view>
        </view>
        <text class="loading-status">{{loadingStatus}}</text>
      </view>
      
      <!-- 游戏状态 -->
      <view class="game-status">
        <view class="status-item">
          <text class="status-icon">🔊</text>
          <text class="status-text">音效: {{soundStatus}}</text>
        </view>
        <view class="status-item">
          <text class="status-icon">🎬</text>
          <text class="status-text">画质: {{videoQuality}}</text>
        </view>
        <view class="status-item">
          <text class="status-icon">📶</text>
          <text class="status-text">连接: {{connectionStatus}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 登录弹窗 -->
  <view class="login-modal" wx:if="{{showLoginModal}}">
    <view class="modal-backdrop"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">欢迎来到无人机飞行</text>
        <view class="modal-close" bindtap="closeLoginModal">
          <text class="close-icon">✕</text>
        </view>
      </view>
      <view class="modal-body">
        <view class="wechat-icon">
          <text class="icon">💚</text>
        </view>
        <text class="modal-message">登录后可享受完整的飞行控制体验</text>
        <button class="login-btn" open-type="getUserInfo" bindgetuserinfo="onGetUserInfo">
          <text class="btn-icon">💚</text>
          <text class="btn-text">使用微信账号登录</text>
        </button>
      </view>
      <view class="modal-footer">
        <text class="footer-text">登录即表示您同意</text>
        <view class="footer-links">
          <text class="link">用户协议</text>
          <text class="link">隐私政策</text>
        </view>
      </view>
    </view>
  </view>
</view>