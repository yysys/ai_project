/* login.wxss */
/* 登录页面样式 - 游戏界面+弹窗登录 */

.login-container {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
}

/* 游戏背景视频 */
.game-background {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.video {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: -1;
}

/* 游戏界面元素 */
.game-interface {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 10;
  display: flex;
  flex-direction: column;
}

/* 游戏标题 */
.game-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 80rpx;
  margin-bottom: 40rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  object-fit: contain;
}

.title-container {
  margin-left: 30rpx;
}

.game-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 10rpx;
  display: block;
}

.game-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
  display: block;
}

/* 游戏主内容 */
.game-content {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.game-preview {
  text-align: center;
}

.drone-image {
  width: 240rpx;
  height: 240rpx;
  object-fit: contain;
  margin-bottom: 40rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

.preview-text {
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.5);
}

.preview-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.preview-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
}

/* 游戏底部 */
.game-footer {
  padding: 40rpx;
  margin-bottom: 40rpx;
}

/* 加载进度条 */
.loading-section {
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(10rpx);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.loading-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.loading-title {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
}

.loading-percentage {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
}

.loading-bar-container {
  width: 100%;
  height: 15rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.loading-bar {
  height: 100%;
  background: linear-gradient(90deg, #07c160 0%, #1890ff 100%);
  border-radius: 10rpx;
  transition: width 0.3s ease;
}

.loading-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  text-align: center;
}

/* 游戏状态 */
.game-status {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: rgba(0, 0, 0, 0.4);
  backdrop-filter: blur(10rpx);
  border-radius: 15rpx;
  padding: 20rpx;
}

.status-item {
  display: flex;
  align-items: center;
}

.status-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.status-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 登录弹窗 */
.login-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(5rpx);
}

.modal-content {
  position: relative;
  z-index: 110;
  background: white;
  border-radius: 30rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 10rpx 50rpx rgba(0, 0, 0, 0.3);
  animation: fadeIn 0.3s ease-out;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  font-size: 32rpx;
  color: #999;
}

.modal-body {
  margin-bottom: 30rpx;
}

.wechat-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.icon {
  font-size: 80rpx;
}

.modal-message {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  text-align: center;
  background: linear-gradient(135deg, #07c160 0%, #06b056 100%);
  color: white;
  border-radius: 45rpx;
  font-size: 32rpx;
  margin-bottom: 30rpx;
  border: none;
  box-shadow: 0 5rpx 15rpx rgba(7, 193, 96, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.btn-text {
  font-size: 32rpx;
}

/* 弹窗底部 */
.modal-footer {
  text-align: center;
}

.footer-text {
  font-size: 20rpx;
  color: #999;
  margin-bottom: 15rpx;
  display: block;
}

.footer-links {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.link {
  font-size: 20rpx;
  color: #1890ff;
}
